# =============================================================================
# Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit your .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# For local dev with docker-compose (postgres maps host port 5433 → container 5432):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5433/exam_prep_db?schema=public"
# Or native Postgres on 5432:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/exam_prep_db?schema=public"
# For Railway (use the reference variable format):
#   DATABASE_URL="${{Postgres.DATABASE_URL}}&schema=public&sslmode=require"
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:<password>@localhost:5432/exam_prep_db?schema=public"

# -----------------------------------------------------------------------------
# Authentication (Auth.js v5)
# Generate with: openssl rand -base64 32
# REQUIRED — app will fail to start without this.
# -----------------------------------------------------------------------------
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

NEXTAUTH_URL="http://localhost:3000"
# Local `npm run dev`: "false" is fine (NODE_ENV=development trusts localhost).
# Docker Compose: docker-compose.yml sets AUTH_TRUST_HOST=true on the app service regardless.
# Railway / Render / reverse proxies: set "true".
AUTH_TRUST_HOST="false"

# -----------------------------------------------------------------------------
# Payload CMS
# Generate with: openssl rand -base64 32
# REQUIRED — app will fail to start without this.
# MUST be at least 16 characters; must not be the placeholder value.
# -----------------------------------------------------------------------------
PAYLOAD_SECRET="replace-with-output-of-openssl-rand-base64-32"
PAYLOAD_DATABASE_URL="${DATABASE_URL}"

# -----------------------------------------------------------------------------
# Admin seed credentials
# REQUIRED when running npm run cms:seed (or docker-entrypoint.sh)
# Generate with: openssl rand -base64 24
# These are used ONCE to create the initial admin account.
# After first deploy, change the password in the admin panel.
# -----------------------------------------------------------------------------
SEED_ADMIN_PASSWORD="replace-with-secure-random-password"
SEED_ADMIN_EMAIL="admin@example.com"

# -----------------------------------------------------------------------------
# pgAdmin (docker-compose local dev only)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL="admin@yourdomain.com"
PGADMIN_PASSWORD="replace-with-strong-pgadmin-password"

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
NODE_ENV="development"
# PORT is injected automatically by Railway; set locally only if needed:
# PORT=3000

# -----------------------------------------------------------------------------
# Logging
# Set to 'true' to enable verbose logging (shows all debug logs)
# Leave as 'false' in production.
# -----------------------------------------------------------------------------
VERBOSE_LOGGING="false"

# -----------------------------------------------------------------------------
# AWS S3 (optional — for cloud media storage)
# If not set, media files are stored locally in public/media/
# -----------------------------------------------------------------------------
# S3-Compatible Storage (AWS S3 or Railway Storage)
# If set, uploads will be stored in S3-compatible storage and the app will not
# rely on the local `public/media` directory.
# -----------------------------------------------------------------------------
# For Railway S3-compatible storage:
# S3_ENDPOINT="https://t3.storageapi.dev"
# AWS_REGION="auto"
# S3_BUCKET="durable-pail-j1frv1nso4hc"
# AWS_ACCESS_KEY_ID="tid_..."  # Railway access key (starts with tid_)
# AWS_SECRET_ACCESS_KEY="..."
#
# For AWS S3:
# AWS_REGION="us-east-1"
# S3_BUCKET="your-bucket-name"
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="..."
# S3_ENDPOINT=""  # Leave empty for AWS
#
# Optional CDN base URL (overrides default URL construction)
# CDN_URL="https://your-cdn.cloudfront.net"

# -----------------------------------------------------------------------------
# Anthropic (Pro lesson assistant — optional)
# Without ANTHROPIC_API_KEY, POST /api/lesson-assistant returns 503.
# Users pick Haiku vs Sonnet in the UI; defaults: Haiku = claude-haiku-4-5, Sonnet = claude-sonnet-4-5.
# Override IDs if needed (snapshots from Anthropic docs):
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-haiku-4-5"
# ANTHROPIC_SONNET_MODEL="claude-sonnet-4-5"

# -----------------------------------------------------------------------------
# OpenAI (Admin AI Agent optional provider)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4.1"

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
# Set to 'true' to skip Payload CMS integration tests (recommended for CI/CD)
SKIP_PAYLOAD_TESTS="false"
# Set to 'true' to skip database setup in tests (for mocked/unit tests only)
SKIP_DB_SETUP="false"

# -----------------------------------------------------------------------------
# Content import (Docker / Railway — docker-entrypoint.sh when CONTENT_IMPORT=1)
# -----------------------------------------------------------------------------
# When "1" or "true", import-courses only creates courses whose slug is new; existing
# courses (and their modules/lessons/tasks) are left as in the database so CMS edits
# survive redeploys. JS changes to an already-imported course are not applied until you
# unset this or use scripts/imports/runners/import-modules.js for targeted appends.
# CONTENT_IMPORT_SKIP_EXISTING_COURSES="1"
