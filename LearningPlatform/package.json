{
  "name": "brainstack",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-10000}",
    "postinstall": "prisma generate",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "cross-env SKIP_DB_SETUP=true vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:telemetry": "vitest run test/telemetry",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx --tsconfig tsconfig.scripts.json ./prisma/seed.ts",
    "db:studio": "prisma studio",
    "payload": "payload",
    "payload:migrate:create": "payload migrate:create",
    "payload:migrate": "tsx --tsconfig tsconfig.scripts.json ./scripts/payload-migrate.ts",
    "payload:fix-media-ids": "tsx --tsconfig tsconfig.scripts.json ./scripts/fix-media-id-columns.ts",
    "cms:seed": "tsx --tsconfig tsconfig.scripts.json ./src/payload/seed.ts",
    "start:staging": "bash scripts/start-staging.sh",
    "preflight": "npm run preflight:check && npm run build",
    "preflight:check": "tsx --tsconfig tsconfig.scripts.json ./scripts/preflight-check.ts",
    "verify:paths": "tsx --tsconfig tsconfig.scripts.json ./scripts/verify-paths.ts",
    "validate:payload-tables": "tsx --tsconfig tsconfig.scripts.json ./scripts/validate-payload-tables.ts",
    "content:import:tags": "tsx --tsconfig tsconfig.scripts.json ./scripts/imports/runners/import-tags.js",
    "content:import:course": "tsx --tsconfig tsconfig.scripts.json ./scripts/imports/runners/import-courses.js",
    "content:import:modules": "tsx --tsconfig tsconfig.scripts.json ./scripts/imports/runners/import-modules.js",
    "content:import:flashcards": "tsx --tsconfig tsconfig.scripts.json ./scripts/imports/runners/import-flashcards.js",
    "content:import:all": "tsx --tsconfig tsconfig.scripts.json ./scripts/imports/runners/import-all.js",
    "payload:cleanup-orphans": "tsx --tsconfig tsconfig.scripts.json ./scripts/cleanup-payload-orphans.ts"
  },
  "prisma": {
    "seed": "tsx --tsconfig tsconfig.scripts.json ./prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.993.0",
    "@payloadcms/db-postgres": "^3.72.0",
    "@payloadcms/next": "^3.72.0",
    "@payloadcms/richtext-lexical": "^3.72.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/katex": "^0.16.8",
    "@types/pg": "^8.16.0",
    "badge-maker": "^5.0.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "katex": "^0.16.27",
    "lucide-react": "^0.563.0",
    "next": "15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "ogl": "^1.0.11",
    "payload": "^3.72.0",
    "pg": "^8.17.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "three": "^0.167.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "jsdom": "^28.1.0",
    "null-loader": "^4.0.1",
    "prettier": "^3.8.1",
    "prisma": "^7.3.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
